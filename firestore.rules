rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if the requester is an admin
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if the request is from the owner
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Attendance collection
    match /attendance/{docId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Schedules collection
    match /schedules/{docId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow write: if isAdmin();
    }

    // Holidays collection
    match /holidays/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Settings collection
    match /settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
